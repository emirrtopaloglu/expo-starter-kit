# Default environment variables. Expo automatically loads these.
# Variables exposed to the client MUST start with the EXPO_PUBLIC_ prefix.

EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_API_KEY=default_public_api_key_placeholder

# RevenueCat Configurations
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=rc_apple_api_key_placeholder
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=rc_google_api_key_placeholder
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
